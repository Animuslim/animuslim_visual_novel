{
  "name": "animuslim",
  "version": "0.2.0",
  "description": "Animuslim — Les Aventures Islamiques pour Enfants. Visual novel éducatif islamique sunnite salafiste pour 5-8 ans.",
  "main": "electron/main.js",
  "author": "animuslimfamily",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "serve": "npx http-server . -p 8080 -c-1"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "@capacitor/cli": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "http-server": "^14.1.1"
  },
  "build": {
    "appId": "com.animuslimfamily.animuslim",
    "productName": "Animuslim",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!**/.gitignore",
      "!**/dist/**",
      "!**/android/**",
      "!**/ios/**",
      "!**/node_modules/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/characters/yusuf_joie.png",
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.education"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Education"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Animuslim"
    }
  }
}
